# Copy this file to .env. Never commit real secrets.
APP_ENV=development
LOG_LEVEL=INFO

# OpenAI: ChatGPT Plus does not include API usage.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.6-terra
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin

# Pollo API
POLLO_API_KEY=
POLLO_API_BASE_URL=https://pollo.ai/api/platform

# YouTube OAuth (enable only when upload automation is added)
YOUTUBE_CLIENT_SECRETS_FILE=secrets/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=secrets/youtube_token.json

# Local paths
DATA_DIR=data
STORAGE_DIR=storage
LOG_DIR=logs
